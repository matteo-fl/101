# Rostelecom API Token (обязательно!)
ROSTELECOM_API_TOKEN=<Your Token>
# API URLs (обычно не нужно менять)
API_BASE_URL=https://ai.rt.ru/api/1.0

# LLM Settings
LLAMA_MODEL=Qwen/Qwen2.5-72B-Instruct
LLAMA_MAX_TOKENS=4096
LLAMA_TEMPERATURE=0.3

# Image Settings
DEFAULT_IMAGE_ASPECT=16:9
IMAGE_GENERATION_TIMEOUT=30

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=True
ENVIRONMENT=development

# File Settings
GENERATED_FILES_DIR=generated_files
MAX_FILE_SIZE_MB=10
MAX_DOCUMENT_CHARS=10000

# CORS Settings
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
